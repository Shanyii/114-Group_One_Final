# ── LLM 設定（ADR Q1：Gemini 開發 / GPT-4o Demo）────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── LLM 供應商選擇：gemini | openai ─────────────────
LLM_PROVIDER=gemini

# ── 模型名稱 ──────────────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=models/gemini-embedding-2

# ── ChromaDB 持久化目錄（ADR Q2）────────────────────
CHROMA_DB_DIR=./chroma_db

# ── 上傳檔案暫存目錄 ──────────────────────────────────
UPLOAD_DIR=./uploads

# ── SQLite 資料庫路徑 ─────────────────────────────────
DATABASE_URL=./learning.db

# ── 伺服器設定（ADR Q3：前後端同機）─────────────────
HOST=0.0.0.0
PORT=8000

# ── Log 保留天數（dev_logs） ──────────────────────────
DEV_LOG_RETENTION_DAYS=30

# ── Rate Limit（每分鐘最多 N 次 /api/task）───────────
RATE_LIMIT_PER_MINUTE=10
